---
// Pillow Studio - MVP
// 45×45 抱枕：Blender GLB mesh + 三種布料材質（棉/麻/絲絨）、上傳圖片、自動旋轉、背景切換
---
<html lang="zh-Hant">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Pillow Studio — Justin's Workshop</title>
  <style>
    :root {
      color-scheme: light;
      --ink: #1b1b1f;
      --muted: #6b6b73;
      --panel: rgba(255,255,255,0.78);
      --border: rgba(0,0,0,0.08);
      --accent: #d97757;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", "PingFang TC", "Noto Sans TC", sans-serif;
      color: var(--ink);
      background: #f5f5f0;
      min-height: 100vh;
    }
    header {
      padding: 18px 24px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: baseline;
      gap: 16px;
    }
    header h1 { font-size: 18px; margin: 0; font-weight: 600; letter-spacing: 0.02em; }
    header .tag { font-size: 12px; color: var(--muted); }
    header a { margin-left: auto; font-size: 13px; color: var(--muted); text-decoration: none; }
    main {
      display: grid;
      grid-template-columns: 320px 1fr;
      gap: 0;
      height: calc(100vh - 57px);
    }
    @media (max-width: 800px) {
      main { grid-template-columns: 1fr; height: auto; }
    }
    aside {
      padding: 22px 22px 28px;
      border-right: 1px solid var(--border);
      overflow-y: auto;
      background: var(--panel);
      backdrop-filter: blur(8px);
    }
    aside h2 {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.12em;
      color: var(--muted);
      margin: 22px 0 10px;
      font-weight: 600;
    }
    aside h2:first-of-type { margin-top: 0; }
    .field { margin-bottom: 6px; }
    .field label {
      display: block;
      font-size: 13px;
      margin-bottom: 6px;
    }
    select, input[type="file"], button {
      width: 100%;
      padding: 8px 10px;
      font-size: 13px;
      border: 1px solid var(--border);
      border-radius: 6px;
      background: white;
      font-family: inherit;
      color: var(--ink);
    }
    button {
      background: var(--ink);
      color: white;
      cursor: pointer;
      border: none;
    }
    button:hover { background: #000; }
    .seg {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 6px;
    }
    .seg.seg-wrap {
      grid-template-columns: repeat(5, 1fr);
    }
    .seg button {
      padding: 7px 4px;
      font-size: 12px;
      background: white;
      color: var(--ink);
      border: 1px solid var(--border);
      cursor: pointer;
    }
    .seg button[aria-pressed="true"] {
      background: var(--ink);
      color: white;
      border-color: var(--ink);
    }
    .stage-wrap {
      position: relative;
      width: 100%;
      height: 100%;
      min-height: 480px;
      background: #efefe9;
    }
    .stage-wrap.bg-solid    { background: #efefe9; }
    .stage-wrap.bg-frosted  { background: linear-gradient(135deg, #e8e1d3 0%, #f5f5f0 60%, #ddd7c8 100%); }
    .stage-wrap.bg-dark     { background: #1a1a1f; }
    .stage-wrap.bg-checker  {
      background-image:
        linear-gradient(45deg, #d6d6cf 25%, transparent 25%),
        linear-gradient(-45deg, #d6d6cf 25%, transparent 25%),
        linear-gradient(45deg, transparent 75%, #d6d6cf 75%),
        linear-gradient(-45deg, transparent 75%, #d6d6cf 75%);
      background-size: 20px 20px;
      background-position: 0 0, 0 10px, 10px -10px, -10px 0;
      background-color: #f5f5f0;
    }
    /* Frosted-glass overlay (for "毛玻璃" mode behind pillow) */
    .stage-wrap.bg-frosted::before {
      content: "";
      position: absolute; inset: 12%;
      background: rgba(255,255,255,0.45);
      backdrop-filter: blur(28px);
      border-radius: 24px;
      pointer-events: none;
      box-shadow: 0 30px 80px rgba(0,0,0,0.08);
    }
    canvas#pillow-canvas {
      display: block;
      width: 100%;
      height: 100%;
      position: relative;
      z-index: 1;
    }
    .hud {
      position: absolute;
      bottom: 14px;
      left: 14px;
      font-size: 11px;
      color: var(--muted);
      background: rgba(255,255,255,0.7);
      padding: 6px 10px;
      border-radius: 6px;
      font-family: ui-monospace, monospace;
      z-index: 2;
    }
    .stage-wrap.bg-dark .hud { background: rgba(0,0,0,0.5); color: #ddd; }

    /* ---- Crop Modal ---- */
    .crop-overlay {
      display: none;
      position: fixed; inset: 0;
      background: rgba(0,0,0,0.55);
      z-index: 100;
      align-items: center; justify-content: center;
      backdrop-filter: blur(4px);
    }
    .crop-modal {
      background: white;
      border-radius: 12px;
      padding: 20px 22px 18px;
      width: min(92vw, 460px);
      box-shadow: 0 20px 60px rgba(0,0,0,0.25);
    }
    .crop-modal h3 { margin: 0 0 4px; font-size: 16px; font-weight: 600; }
    .crop-modal .crop-aspect { font-size: 12px; color: var(--muted); margin-bottom: 12px; }
    .crop-mode-seg {
      display: grid; grid-template-columns: 1fr 1fr; gap: 6px; margin-bottom: 12px;
    }
    .crop-mode-seg button {
      padding: 8px 4px; font-size: 13px;
      background: white; color: var(--ink);
      border: 1px solid var(--border); border-radius: 6px; cursor: pointer;
    }
    .crop-mode-seg button[aria-pressed="true"] {
      background: var(--ink); color: white; border-color: var(--ink);
    }
    #crop-preview {
      width: 100%; aspect-ratio: 1/1; display: block;
      border: 1px solid var(--border); border-radius: 8px;
      cursor: grab; background: #fafafa;
    }
    #crop-preview:active { cursor: grabbing; }
    .crop-zoom-row {
      display: flex; align-items: center; gap: 10px;
      margin-top: 10px; font-size: 12px; color: var(--muted);
    }
    .crop-zoom-row input[type="range"] { flex: 1; }
    .crop-hint {
      font-size: 12px; color: var(--muted);
      margin-top: 8px; line-height: 1.45;
      min-height: 32px;
    }
    .crop-actions {
      display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 14px;
    }
    .crop-actions button {
      padding: 9px; font-size: 13px; border-radius: 6px; cursor: pointer;
      border: 1px solid var(--border);
    }
    #crop-cancel { background: white; color: var(--ink); }
    #crop-confirm { background: var(--ink); color: white; border-color: var(--ink); }
  </style>
</head>
<body>
  <header>
    <h1>Pillow Studio</h1>
    <span class="tag">v2 · 45×45 · GLB mesh · 棉/麻/絲絨</span>
    <a href="/">← back to workshop</a>
  </header>
  <main>
    <aside>
      <h2>1. 上傳圖案</h2>
      <div class="field">
        <input type="file" id="img-upload" accept="image/*" />
      </div>
      <div class="crop-hint" style="margin-top:-4px;">
        非 1:1 比例會跳出裁切視窗讓你選「裁切」或「保留全圖（露出布料）」
      </div>

      <h2>2. 尺寸</h2>
      <div class="field">
        <select id="size" disabled>
          <option value="45x45">45 × 45 cm（標準方枕）</option>
          <option value="40x40" disabled>40 × 40 cm — MVP 後解鎖</option>
          <option value="50x50" disabled>50 × 50 cm — MVP 後解鎖</option>
          <option value="30x50" disabled>30 × 50 cm 腰枕 — MVP 後解鎖</option>
          <option value="65x65" disabled>65 × 65 cm Euro — MVP 後解鎖</option>
        </select>
      </div>

      <h2>3. 布料</h2>
      <div class="field">
        <select id="fabric">
          <option value="cotton">棉布 Cotton（啞光、微紋理）</option>
          <option value="linen">麻 Linen（粗紋、霧面）</option>
          <option value="velvet">絲絨 Velvet（柔光、細絨）</option>
        </select>
      </div>

      <h2>4. 列印面積</h2>
      <div class="seg seg-wrap" id="print-area-seg">
        <button data-print-scale="1.00" aria-pressed="true">滿版</button>
        <button data-print-scale="0.90" aria-pressed="false">90%</button>
        <button data-print-scale="0.80" aria-pressed="false">80%</button>
        <button data-print-scale="0.70" aria-pressed="false">70%</button>
        <button data-print-scale="0.60" aria-pressed="false">60%</button>
      </div>
      <div class="crop-hint" id="print-area-hint" style="margin-top:-4px;">
        印刷區會等比例縮小至中央，四周露出布料底紋
      </div>

      <h2>5. 圖案位置</h2>
      <div class="seg" id="face-seg">
        <button data-face="front" aria-pressed="true">正面</button>
        <button data-face="back" aria-pressed="false">反面</button>
        <button data-face="both" aria-pressed="false">兩面同圖</button>
      </div>

      <h2>6. 底色（圖以外區域）</h2>
      <div class="field">
        <input type="color" id="base-color" value="#e8dccb" style="width: 100%; height: 40px; padding: 2px; cursor: pointer;" />
      </div>

      <h2>7. 背景</h2>
      <div class="seg" id="bg-seg">
        <button data-bg="solid" aria-pressed="true">純色</button>
        <button data-bg="frosted" aria-pressed="false">毛玻璃</button>
        <button data-bg="dark" aria-pressed="false">深色</button>
      </div>
      <div class="seg" style="margin-top:6px;">
        <button data-bg="checker">棋盤格</button>
      </div>

      <h2>8. 操作</h2>
      <div class="field">
        <button id="reset-cam">重設視角</button>
      </div>
      <div class="field">
        <button id="auto-rotate" aria-pressed="false">⟳ 自動旋轉</button>
      </div>
    </aside>

    <section class="stage-wrap bg-solid" id="stage">
      <canvas id="pillow-canvas"></canvas>
      <div class="hud" id="hud">loading three.js…</div>
    </section>
  </main>

  <!-- ===== Crop Modal ===== -->
  <div class="crop-overlay" id="crop-overlay">
    <div class="crop-modal">
      <h3>調整圖片以符合抱枕比例</h3>
      <div class="crop-aspect" id="crop-aspect">—</div>

      <div class="crop-mode-seg">
        <button data-crop-mode="crop" aria-pressed="true">裁切（鋪滿）</button>
        <button data-crop-mode="fit" aria-pressed="false">保留全圖（露布料）</button>
      </div>

      <canvas id="crop-preview" width="400" height="400"></canvas>

      <div class="crop-zoom-row">
        <span>縮放</span>
        <input type="range" id="crop-zoom" min="1" max="3" step="0.01" value="1" />
      </div>

      <div class="crop-hint" id="crop-hint">—</div>

      <div class="crop-actions">
        <button id="crop-cancel">取消</button>
        <button id="crop-confirm">確認套用</button>
      </div>
    </div>
  </div>

  <script type="importmap">
    {
      "imports": {
        "three": "https://unpkg.com/three@0.170.0/build/three.module.js",
        "three/addons/": "https://unpkg.com/three@0.170.0/examples/jsm/"
      }
    }
  </script>
  <script type="module" src="/pillow-studio.js"></script>
</body>
</html>
